{
  "name": "stealth-address-payment-system",
  "version": "1.0.0",
  "private": true,
  "description": "Privacy-preserving Bitcoin payment system using stealth addresses on top of BitGo wallets",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "db:generate": "pnpm --filter @stealth/db prisma generate",
    "db:migrate": "pnpm --filter @stealth/db prisma migrate dev",
    "db:studio": "pnpm --filter @stealth/db prisma studio",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "prepare": "husky"
  },
  "keywords": [
    "bitcoin",
    "stealth-address",
    "privacy",
    "bitgo",
    "crypto"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.26.2",
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "**/*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "@polkadot/util": "13.5.6",
      "@polkadot/util-crypto": "13.5.6",
      "@polkadot/wasm-crypto": "7.5.4",
      "@polkadot/wasm-bridge": "7.5.4",
      "@polkadot/wasm-crypto-wasm": "7.5.4",
      "@polkadot/wasm-util": "7.5.4",
      "@polkadot/keyring": "13.5.6"
    },
    "ignoredBuiltDependencies": [
      "bufferutil",
      "cbor-extract",
      "eccrypto",
      "es5-ext",
      "keccak",
      "protobufjs",
      "sodium-native",
      "utf-8-validate"
    ],
    "onlyBuiltDependencies": [
      "bigint-buffer",
      "secp256k1"
    ]
  }
}
