{
  "name": "stealth-address-payment-system",
  "version": "1.0.0",
  "private": true,
  "description": "Privacy-preserving Bitcoin payment system using stealth addresses on top of BitGo wallets",
  "scripts": {
    "dev": "pnpm run dev:all",
    "dev:all": "turbo run dev --parallel --ui=stream --filter=@stealth/web --filter=@stealth/scanner --filter=@stealth/shared --filter=@stealth/crypto --filter=@stealth/db --filter=@stealth/bitgo-client",
    "dev:web": "pnpm --filter @stealth/web dev",
    "dev:scanner": "pnpm --filter @stealth/scanner dev",
    "dev:core": "turbo run dev --parallel --ui=stream --filter=@stealth/web --filter=@stealth/scanner",
    "build": "turbo run build",
    "build:web": "pnpm --filter @stealth/web build",
    "build:scanner": "pnpm --filter @stealth/scanner build",
    "typecheck": "tsc --noEmit",
    "typecheck:packages": "turbo run lint --filter=@stealth/*",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "start:web": "pnpm --filter @stealth/web start",
    "start:scanner": "pnpm --filter @stealth/scanner start",
    "check-ports": "pnpm ports:check",
    "kill-ports": "pnpm ports:kill",
    "ports:check": "node ./scripts/check-ports.cjs",
    "ports:kill": "node ./scripts/kill-ports.cjs",
    "ports:kill:all": "node ./scripts/kill-ports.cjs 3000 3001 5432",
    "stop:dev": "pnpm ports:kill",
    "clean": "turbo run clean",
    "clean:all": "pnpm clean && rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "db:types": "supabase gen types typescript --local > packages/db/src/database.types.ts",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "prepare": "husky"
  },
  "keywords": [
    "bitcoin",
    "stealth-address",
    "privacy",
    "bitgo",
    "crypto"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.26.2",
  "dependencies": {
    "@polkadot/util": "13.5.6",
    "@scopelift/stealth-address-sdk": "1.0.0-beta.2",
    "bitgo": "^50.26.2",
    "readline-sync": "^1.4.10"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "turbo": "^2.3.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "**/*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "@polkadot/util": "13.5.6",
      "@polkadot/util-crypto": "13.5.6",
      "@polkadot/wasm-crypto": "7.5.4",
      "@polkadot/wasm-bridge": "7.5.4",
      "@polkadot/wasm-crypto-wasm": "7.5.4",
      "@polkadot/wasm-util": "7.5.4",
      "@polkadot/keyring": "13.5.6"
    },
    "ignoredBuiltDependencies": [
      "bufferutil",
      "cbor-extract",
      "eccrypto",
      "es5-ext",
      "keccak",
      "protobufjs",
      "sodium-native",
      "utf-8-validate"
    ],
    "onlyBuiltDependencies": [
      "bigint-buffer",
      "secp256k1"
    ]
  }
}
