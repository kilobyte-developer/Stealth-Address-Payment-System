// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  wallets Wallet[]
}

// ─── Wallets ──────────────────────────────────────────────────────────────────

model Wallet {
  id             String   @id @default(cuid())
  userId         String
  label          String
  bitgoWalletId  String   @unique
  network        String   @default("tbtc") // "tbtc" | "btc"

  // Stealth key pair — private keys stored encrypted (AES-256-GCM)
  encryptedViewPrivKey  String // a (encrypted)
  encryptedSpendPrivKey String // b (encrypted)
  publicViewKey         String // A = a·G (compressed hex)
  publicSpendKey        String // B = b·G (compressed hex)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     Transaction[]
  detectedPayments DetectedPayment[]
}

// ─── Transactions ─────────────────────────────────────────────────────────────

model Transaction {
  id       String @id @default(cuid())
  walletId String

  txHash            String    @unique
  direction         String    // "send" | "receive"
  amountSats        Int
  feeSats           Int       @default(0)
  ephemeralPublicKey String?  // R — only for stealth sends
  oneTimeAddress    String?   // P — the output address

  status      String    @default("pending") // "pending"|"confirmed"|"failed"
  note        String?
  createdAt   DateTime  @default(now())
  confirmedAt DateTime?

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

// ─── Detected Stealth Payments ────────────────────────────────────────────────

model DetectedPayment {
  id       String @id @default(cuid())
  walletId String

  txHash             String  @unique
  oneTimeAddress     String  // P
  ephemeralPublicKey String  // R
  amountSats         Int
  blockHeight        Int?

  spentTxHash String?  // set when funds are swept
  spentAt     DateTime?

  createdAt DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

// ─── Scanner State ────────────────────────────────────────────────────────────

model ScannerState {
  id               String   @id @default(cuid())
  walletId         String   @unique
  lastScannedBlock Int      @default(0)
  updatedAt        DateTime @updatedAt
}
