# ─── BitGo ────────────────────────────────────────────────────────────
BITGO_ENV=test
BITGO_ACCESS_TOKEN=
BITGO_ENTERPRISE_ID=

# ─── Database ─────────────────────────────────────────────────────────
# SQLite (local dev)
DATABASE_URL=file:./dev.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/stealth_payments

# ─── API Server ───────────────────────────────────────────────────────
API_PORT=4000
JWT_SECRET=change-me-to-at-least-32-random-chars
JWT_EXPIRY=24h
CORS_ORIGIN=http://localhost:3000

# ─── Scanner ──────────────────────────────────────────────────────────
SCAN_INTERVAL_MS=30000
SCAN_BLOCK_BATCH_SIZE=10

# ─── Frontend (must be prefixed NEXT_PUBLIC_) ─────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
